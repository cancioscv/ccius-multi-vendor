{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "NodeNext",
    "types": ["node"],
    "rootDir": "../../",
    "moduleResolution": "NodeNext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "target": "ES2022"
  },
  "include": [
    "src/**/*.ts",
    "../auth-service/",
    "../auth-service/src/swagger/swagger-output.json",
    "../../packages/**/*.ts"
  ],
  "exclude": [],
  "references": [
    {
      "path": "../../packages/db/tsconfig.lib.json"
    },
    {
      "path": "../../packages/libs/tsconfig.lib.json"
    }
  ]
}
