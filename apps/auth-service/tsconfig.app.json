{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "NodeNext",
    "types": ["node"],
    "rootDir": "../../",
    "moduleResolution": "NodeNext",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "composite": false
  },
  "include": ["src/**/*.ts", "../auth-service/", "../auth-service/src/swagger/swagger-output.json", "../../packages/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../../packages/kafka/tsconfig.lib.json"
    },
    {
      "path": "../../packages/db/tsconfig.lib.json"
    },
    {
      "path": "../../packages/libs/tsconfig.lib.json"
    }
  ]
}
